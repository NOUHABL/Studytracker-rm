{
  "manifest_version": 3,
  "name": "StudyTracker",
  "version": "1.0.0",
  "description": "Track browsing activity during study sessions.",

  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "alarms"
  ],

  "host_permissions": [
    "http://localhost:3000/*",
    "http://localhost:3001/*",
    "https://*.vercel.app/*",
    "https://your-api-domain.com/*"
  ],

  "background": {
    "service_worker": "src/background.js"
  },

  "content_scripts": [
    {
      "matches": ["http://localhost:3000/*", "https://*.vercel.app/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html"
  }
}